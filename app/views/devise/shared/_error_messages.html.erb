<% if resource.errors.any? %>
  <div id="error_explanation" data-turbo-temporary
       class="mb-md rounded-lg border border-error/40 bg-error-container text-on-error-container p-md">
    <p class="font-label-md text-label-md mb-xs">
      <%= I18n.t("errors.messages.not_saved",
                 count: resource.errors.count,
                 resource: resource.class.model_name.human.downcase) %>
    </p>
    <ul class="list-disc list-inside space-y-xs font-body-md text-body-md">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
