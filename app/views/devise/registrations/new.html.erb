<% content_for :title, "新規登録 - ねこの集会場" %>

<div class="min-h-screen flex flex-col items-center justify-center">
  <!-- Header / Brand Section -->
  <header class="mb-lg text-center px-gutter">
    <h1 class="font-headline-lg text-headline-lg text-on-background mb-xs">ねこの集会場</h1>
    <p class="font-label-md text-label-md text-on-surface-variant tracking-widest uppercase">Empathetic Responsibility</p>
  </header>

  <main class="w-full max-w-[480px] px-margin-mobile md:px-0">
    <!-- Auth Container -->
    <div class="bg-surface-container-lowest rounded-xl p-md md:p-lg auth-card-shadow border border-outline-variant/30">
      <h2 class="font-headline-md text-headline-md text-on-surface mb-md text-center">新規登録</h2>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-md" }) do |f| %>
        <div class="space-y-xs">
          <%= f.label :username, "ユーザー名（ニックネーム）", class: "font-label-md text-label-md text-on-surface-variant" %>
          <%= f.text_field :username, autofocus: true, placeholder: "にゃん太郎",
                class: "w-full h-[48px] px-md rounded-lg border border-outline-variant bg-surface-bright input-focus-ring font-body-md" %>
        </div>
        <div class="space-y-xs">
          <%= f.label :name, "お名前", class: "font-label-md text-label-md text-on-surface-variant" %>
          <%= f.text_field :name, placeholder: "山田 太郎",
                class: "w-full h-[48px] px-md rounded-lg border border-outline-variant bg-surface-bright input-focus-ring font-body-md" %>
        </div>
        <div class="space-y-xs">
          <%= f.label :email, "メールアドレス", class: "font-label-md text-label-md text-on-surface-variant" %>
          <%= f.email_field :email, autocomplete: "email", placeholder: "example@email.com",
                class: "w-full h-[48px] px-md rounded-lg border border-outline-variant bg-surface-bright input-focus-ring font-body-md" %>
        </div>
        <div class="space-y-xs">
          <%= f.label :password, "パスワード", class: "font-label-md text-label-md text-on-surface-variant" %>
          <%= f.password_field :password, autocomplete: "new-password",
                placeholder: "#{@minimum_password_length}文字以上",
                class: "w-full h-[48px] px-md rounded-lg border border-outline-variant bg-surface-bright input-focus-ring font-body-md" %>
        </div>

        <div class="flex items-start gap-sm py-xs">
          <%= check_box_tag "terms", "1", false, required: true,
                id: "terms", class: "mt-1 rounded border-outline-variant text-primary accent-primary focus:ring-primary h-4 w-4" %>
          <label class="font-body-md text-body-md text-on-surface-variant" for="terms">
            <a class="text-primary hover:underline font-semibold" href="#">利用規約</a>と<a class="text-primary hover:underline font-semibold" href="#">プライバシーポリシー</a>に同意します。猫の生涯に責任を持つことを誓います。
          </label>
        </div>

        <%= f.submit "アカウントを作成",
              class: "w-full h-[48px] bg-primary-container text-on-primary-container font-headline-sm text-headline-sm rounded-lg hover:opacity-90 active:scale-[0.98] transition-all shadow-sm cursor-pointer" %>

        <div class="text-center mt-md">
          <%= link_to "すでにアカウントをお持ちの方はこちら（ログイン）", new_session_path(resource_name), class: "font-label-md text-label-md text-primary hover:underline" %>
        </div>
      <% end %>
    </div>
  </main>

  <!-- Footer -->
  <footer class="mt-xl py-lg w-full max-w-[1200px] flex flex-col md:flex-row items-center px-gutter gap-md justify-center text-center">
    <p class="font-label-sm text-label-sm text-on-surface-variant/60">© 2026 ねこの集会場. Empathetic Responsibility for Feline Life.</p>
    <div class="gap-lg inline-flex justify-center">
      <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors" href="#">利用規約</a>
      <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors" href="#">プライバシー</a>
      <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors" href="#">お問い合わせ</a>
    </div>
  </footer>

  <!-- Decorative Elements (Atmospheric) -->
  <div class="fixed top-[-10%] right-[-5%] w-[400px] h-[400px] bg-primary/5 rounded-full blur-[100px] -z-10"></div>
  <div class="fixed bottom-[-10%] left-[-5%] w-[400px] h-[400px] bg-tertiary/5 rounded-full blur-[100px] -z-10"></div>

  <!-- Decorative Paw Prints -->
  <span class="material-symbols-outlined fixed top-[12%] left-[14%] text-[32px] rotate-12 -z-10 select-none text-[#f9c54e]/20">pets</span>
  <span class="material-symbols-outlined fixed top-[45%] right-[8%] text-[64px] rotate-45 -z-10 select-none text-[#f9c54e]/20">pets</span>
  <span class="material-symbols-outlined fixed top-[48%] right-[12%] text-[40px] rotate-[60deg] -z-10 select-none text-[#f9c54e]/20">pets</span>
  <span class="material-symbols-outlined fixed bottom-[15%] right-[20%] text-[56px] -rotate-[30deg] -z-10 select-none text-[#f9c54e]/20">pets</span>
  <span class="material-symbols-outlined fixed bottom-[20%] left-[15%] text-[44px] rotate-[15deg] -z-10 select-none text-[#f9c54e]/20">pets</span>
</div>
