<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Myapp" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%# ホーム画面に追加したときにフルスクリーンで開く指定。apple- 付きは非推奨のため両方書く %>
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap">

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-background text-on-surface font-body-md">
    <% if notice.present? %>
      <div data-turbo-temporary
           class="fixed top-gutter left-1/2 -translate-x-1/2 z-50 max-w-[480px] w-[90%] rounded-lg border border-primary/30 bg-surface-container-high text-on-surface p-md shadow-sm font-body-md text-body-md text-center">
        <%= notice %>
      </div>
    <% end %>
    <% if alert.present? %>
      <div data-turbo-temporary
           class="fixed top-gutter left-1/2 -translate-x-1/2 z-50 max-w-[480px] w-[90%] rounded-lg border border-error/40 bg-error-container text-on-error-container p-md shadow-sm font-body-md text-body-md text-center">
        <%= alert %>
      </div>
    <% end %>

    <%= yield %>

    <%# 画像ライトボックス（js-zoomable な画像をクリックで全体表示） %>
    <div id="image-lightbox" style="z-index: 100;" class="hidden fixed inset-0 bg-black/80 items-center justify-center p-4 cursor-zoom-out">
      <!-- ねこの顔の×クローズボタン（Tailwind非依存でインライン指定） -->
      <button type="button" aria-label="閉じる"
              style="position:absolute; top:20px; right:20px; width:48px; height:48px; border-radius:9999px; background:#ffffff; color:#201a14; display:flex; align-items:center; justify-content:center; box-shadow:0 10px 15px -3px rgba(0,0,0,.3); cursor:pointer;">
        <span style="position:absolute; top:-6px; left:6px; width:0; height:0; border-left:8px solid transparent; border-right:8px solid transparent; border-bottom:13px solid #ffffff; transform:rotate(-28deg);"></span>
        <span style="position:absolute; top:-6px; right:6px; width:0; height:0; border-left:8px solid transparent; border-right:8px solid transparent; border-bottom:13px solid #ffffff; transform:rotate(28deg);"></span>
        <span class="material-symbols-outlined" style="font-size:26px;">close</span>
      </button>
      <img class="max-w-full max-h-full object-contain rounded-lg shadow-2xl" alt="">
    </div>
    <script>
      (function () {
        if (window.__lightboxBound) return;
        window.__lightboxBound = true;

        function closeLightbox() {
          const overlay = document.getElementById("image-lightbox");
          if (overlay) { overlay.classList.add("hidden"); overlay.classList.remove("flex"); }
        }

        document.addEventListener("click", function (e) {
          const overlay = document.getElementById("image-lightbox");
          if (!overlay) return;
          // 開いている時にオーバーレイをクリックしたら閉じる
          if (!overlay.classList.contains("hidden") && overlay.contains(e.target)) {
            closeLightbox();
            return;
          }
          // 拡大対象の画像をクリックしたら開く
          const img = e.target.closest("img.js-zoomable");
          if (img) {
            const full = overlay.querySelector("img");
            full.src = img.currentSrc || img.src;
            full.alt = img.alt || "";
            overlay.classList.remove("hidden");
            overlay.classList.add("flex");
          }
        });

        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape") closeLightbox();
        });
      })();
    </script>
  </body>
</html>
